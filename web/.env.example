# Parkno lead capture — set these in Vercel → Project → Settings → Environment
# Variables (NOT committed; .env is gitignored). Copy to .env for local dev.

# Required — Supabase project (Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # server-only, never ship to client

# Optional — Resend (https://resend.com) enables notification + confirmation email.
# Without it, leads are still stored; only the emails are skipped.
RESEND_API_KEY=
LEAD_NOTIFY_TO=kontakt@parkno.no
LEAD_FROM=Parkno <noreply@parkno.no>            # sender domain must be verified in Resend
